class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        string a = "";
        int b = 0;

        for(int i = 0; i < s.size(); i++){
            a = ""; 
            for(int j = i; j < s.size(); j++){
                if(count(a.begin(), a.end(), s[j]) > 0){
                    break;
                }
                else{
                    a = a + s[j];
                    b = max(b, (int)a.size());
                }
            }
        }
        return b;
    }
};
