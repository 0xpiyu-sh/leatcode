/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* middleNode(ListNode* head) {
        ListNode* temp = new ListNode;
        temp = head;
        int i=0;
        while(temp!=NULL){
            i++;
            temp=temp->next;
        }
        if(i%2 != 0){
            int m = (i+1)/2;
            int j=0;
            temp = head;
            while(temp!=NULL){
                j++;
                if(j==m)return temp;      
                temp=temp->next;
            }
        }
        else{
            int m = i/2+1;
            int j=0;
            temp = head;
            while(temp!=NULL){
                j++;
                if(j==m)return temp;      
                temp=temp->next;
            }
        }
        return head;
    }
};
