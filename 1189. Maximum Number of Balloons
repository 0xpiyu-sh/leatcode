class Solution {
public:
    int maxNumberOfBalloons(string text) {
        int b=0,a=0,l=0,o=0,n=0;
        for(char i:text){
            if(i=='b')b++;
            if(i=='a')a++;
            if(i=='l')l++;
            if(i=='o')o++;
            if(i=='n')n++;
        }
        return min({b, a, l/2, o/2, n});
    }
};
