class Solution {
public:
    int timeRequiredToBuy(vector<int>& tickets, int k) {
        queue<pair<int,int>> a;

        for(int i = 0; i < tickets.size(); i++) {
            a.push({tickets[i], i});
        }

        int b = 0;

        while(!a.empty()) {
            auto c = a.front();
            a.pop();

            c.first--;
            b++;

            if(c.first == 0) {
                if(c.second == k)
                    return b;
            } else {
                a.push(c);
            }
        }
        return b;
    }
};
