class Solution {
public:
    int findTheWinner(int n, int k) {
        vector<int> a;
        for (int i = 1; i <= n; i++) {
            a.push_back(i);
        }

        int b = 0;
        while (a.size() != 1) {
            b = (b + k - 1) % a.size();
            a.erase(a.begin() + b);
        }

        return a[0];
    }
};
