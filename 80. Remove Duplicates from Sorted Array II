class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n = nums.size();
        if(n <= 2) return n;
        vector<int>b;
        b.push_back(nums[0]);
        b.push_back(nums[1]);
        int j=0;
        for(int i=2;i<nums.size();i++){
            if(nums[i]==b[j]){
                continue;
            }
            else{
                b.push_back(nums[i]);
                j++;
            }
        }
        nums.resize(b.size());
        for(int i=0;i<b.size();i++){
            nums[i]=b[i];
        }
        return b.size();
    }
};
