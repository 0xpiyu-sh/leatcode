class Solution {
public:
    string clearDigits(string s) {
        stack<char> a;

        for(int i = 0; i < s.size(); i++) {
            if(isdigit(s[i])) {
                if(!a.empty()) {
                    a.pop();
                }
            }
            else {
                a.push(s[i]);
            }
        }

        s = "";

        while(!a.empty()) {
            s += a.top();
            a.pop();
        }

        reverse(s.begin(), s.end());
        return s;
    }
};
