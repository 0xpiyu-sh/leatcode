class Solution {
public:
    vector<vector<int>> generate(int numRows) {
        vector<vector<int>> a(numRows);
        for(int i = 0; i < numRows; i++) {
            a[i].resize(i + 1);
        }
        a[0][0]=1;
        if(numRows==1)return a;
        a[1][0]=1;
        a[1][1]=1;
        if(numRows==2){
            return a;
        }
        for(int i=2;i<numRows;i++){
            for(int j=0;j<=i;j++){
                if(j==0){
                    a[i][j]=1;
                }
                else if(i==j){
                    a[i][j]=1;
                }
                else{
                    a[i][j]=a[i-1][j-1]+a[i-1][j];
                }
            }
        }
        return a;
    }
};
