class Solution {
public:
    void rotate(vector<vector<int>>& matrix) {
        vector<vector<int>> mat=matrix;
        int m = matrix.size();
        int n = matrix[0].size();
        for(int i =0; i<m; i++){
            for(int j = 0; j<n; j++){
                mat[j][i]=matrix[i][j];
            }
        }
        for(int i=0; i<m;i++){
            reverse(mat[i].begin(),mat[i].end());
        }
        matrix.clear();
        matrix=mat;
    }
};
