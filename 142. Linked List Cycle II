/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
 */
class Solution {
public:
    ListNode *detectCycle(ListNode *head) {
        vector<ListNode*> a;
        ListNode* temp = head;
        while(true){
            if(temp==NULL)return NULL;
            int z=count(a.begin(),a.end(),temp);
            if(z>1)return temp;
            a.push_back(temp);
            temp=temp->next;
        }
        return NULL;
    }
};
