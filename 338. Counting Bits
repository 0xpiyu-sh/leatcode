class Solution {
public:
    vector<int> countBits(int n) {
        vector<int> a;
        for(int i=0;i<=n;i++){
            if(i==0){
                a.push_back(0);
                continue;
            }
            else if(i==1){
                a.push_back(1);
                continue;
            }
            string b = bitset<64>(i).to_string();
            a.push_back(count(b.begin(),b.end(),'1'));
        }
        return a;
    }
};
