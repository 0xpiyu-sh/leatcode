class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        int n = nums.size();

        vector<int> nums1(n, 0);
        vector<int> nums2(n, 0);
        vector<int> nums3(n, 0);

        for(int i = 1; i < n; i++) {
            nums1[i] = nums1[i - 1] + nums[i - 1];
        }

        for(int i = n - 2; i >= 0; i--) {
            nums2[i] = nums2[i + 1] + nums[i + 1];
        }

        for(int i = 0; i < n; i++) {
            nums3[i] = abs(nums1[i] - nums2[i]);
        }

        return nums3;
    }
};
