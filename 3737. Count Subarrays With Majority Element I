class Solution {
public:
    int countMajoritySubarrays(vector<int>& nums, int target) {
    long long a=0;
    for(int i=0;i<nums.size();i++){
        long long b=0;
        for(int j=i;j<nums.size();j++){
            if(nums[j]==target)b++;
            int len = j - i + 1;
                if (b > len / 2)
                    a++;
        }
    }
    return a;
    }
};
