class Solution {
public:
    string reverseWords(string s) {
        string w;
        vector<string>a;
        stringstream ss(s);
        while(ss>>w){
            a.push_back(w);
        }
        w="";
        reverse(a.begin(),a.end());
        for(int i=0;i<a.size();i++){
            w+=a[i];
            if(i!=a.size()-1)w+=" ";
        }
        
        return w;
    }
};
