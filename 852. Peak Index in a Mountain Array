class Solution {
public:
    int peakIndexInMountainArray(vector<int>& arr) {
        int low =1;
        int high=arr.size()-2;
        int a=0;
        while(low<=high){
            int mid = (low + high)/2;
            if((arr[mid-1]<arr[mid])&&(arr[mid+1]<arr[mid])){
                a=mid;
                break;
            }
            else if(arr[mid-1]<arr[mid]){
                low=mid+1;
            }
            else if(arr[mid+1]<arr[mid]){
                high=mid-1;
            }
        }
        
        return a;
    }
};
