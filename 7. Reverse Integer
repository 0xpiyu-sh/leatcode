class Solution {
public:
    int reverse(int x) {
        string a=to_string(x);
        long long z=1;
        long long b=0;
        for(int i=0;i<a.size();i++){
            if(a[i]=='-')continue;
            b+=(a[i]-48)*z;
            z*=10;
        }
        if(x<0)b=0-b;
        if (b > INT_MAX || b < INT_MIN)
            return 0;

        return (int)b;
    }
};
